<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Profile | Notetaking App</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <%- include('../partials/header') %>
  <main id="main-content" class="dashboard-page">
    <section class="dashboard-header">
      <div>
        <p class="dashboard-kicker">Profile</p>
        <h1><%= user && user.username ? user.username : 'Your Account' %></h1>
        <p>View and manage your account details.</p>
      </div>

      <div class="dashboard-actions">
        <a href="/user/profile/edit" class="btn btn-primary">Edit Profile</a>
      </div>
    </section>

    <section class="dashboard-grid profile-grid" aria-label="Profile details">
      <article class="dashboard-card profile-card">
        <h2>Account Details</h2>

        <dl class="profile-details">
          <div>
            <dt>Username</dt>
            <dd><%= user && user.username ? user.username : 'Not set' %></dd>
          </div>

          <div>
            <dt>Email</dt>
            <dd><%= user && user.email ? user.email : 'Not set' %></dd>
          </div>

          <% if (user && user.createdAt) { %>
            <div>
              <dt>Member Since</dt>
              <dd><%= new Date(user.createdAt).toLocaleDateString('en-ca') %></dd>
            </div>
          <% } %>
        </dl>
      </article>

      <article class="dashboard-card profile-card">
        <h2>Account Actions</h2>
        <p>Delete your account only if you no longer need your notes or collections.</p>

        <form action="/user/profile?_method=DELETE" method="POST" class="danger-form" data-delete-account-form>
          <button type="submit" class="btn btn-danger" data-confirm-delete-button aria-describedby="delete-account-status">
            Delete Account
          </button>
          <button type="button" class="btn btn-secondary nevermind" data-cancel-delete-button hidden>
            Nevermind
          </button>
          <p id="delete-account-status" class="delete-account-status" role="status" aria-live="polite"></p>
        </form>
      </article>
    </section>
  </main>

  <%- include('../partials/footer') %>
  <script src="/js/profile.js"></script>
</body>
</html>
