<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>New Collection | Notetaking App</title>
  <link rel="stylesheet" href="/css/style.css">
  <script src="/js/collectionColors.js" defer></script>
</head>
<body>
  <%- include('../partials/header') %>
  <main id="main-content" class="dashboard-page">
    <section class="dashboard-header">
      <div>
        <p class="dashboard-kicker">Collections</p>
        <h1>Create a Collection</h1>
        <p>Give a group of notes a name and a colour that makes it easy to spot.</p>
      </div>
      <a href="/collections" class="btn btn-secondary">Back to Collections</a>
    </section>

    <section class="dashboard-card" style="margin-top: 24px;">
      <form action="/collections" method="POST" class="profile-details">
        <div>
          <label for="name">Collection name</label>
          <input id="name" name="name" type="text" list="collection-suggestions" maxlength="50" required>
          <datalist id="collection-suggestions">
            <option value="💼 Work"></option>
            <option value="🎓 School"></option>
            <option value="🏠 Personal"></option>
            <option value="🍳 Cooking"></option>
            <option value="🎨 Hobby"></option>
            <option value="🏃 Health & Fitness"></option>
            <option value="✈️ Travel"></option>
            <option value="📚 Reading"></option>
          </datalist>
          <p class="form-hint">Popular ideas: 💼 Work, 🎓 School, 🏠 Personal, 🍳 Cooking, 🎨 Hobby, and more.</p>
        </div>
        <div>
          <label for="description">Description <span class="form-optional">(optional)</span></label>
          <textarea id="description" name="description" rows="4" maxlength="250"></textarea>
        </div>
        <div>
          <label for="color">Collection colour</label>
          <select id="color" name="color" data-collection-color-select aria-describedby="color-hint"></select>
          <p id="color-hint" class="form-hint">Choose one of the 10 collection colours.</p>
        </div>
        <div class="dashboard-actions">
          <button type="submit" class="btn btn-primary">Create Collection</button>
          <a href="/collections" class="btn btn-secondary">Cancel</a>
        </div>
      </form>
    </section>
  </main>
  <%- include('../partials/footer') %>
</body>
</html>
